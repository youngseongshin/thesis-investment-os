{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thesis-os.org/schemas/prediction.schema.json",
  "title": "Prediction",
  "type": "object",
  "required": ["id", "entity", "thesis_id", "prediction", "direction", "horizon", "created_at", "evaluation_due"],
  "properties": {
    "id": {"type": "string"},
    "entity": {"type": "string"},
    "thesis_id": {"type": "string"},
    "prediction": {"type": "string"},
    "direction": {"type": "string", "enum": ["up", "down", "neutral", "relative_outperform", "relative_underperform"]},
    "horizon": {"type": "string", "description": "Native evaluation horizon, for example 1m, 6m, 1y, or 21 trading days."},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "created_at": {"type": "string"},
    "evaluation_due": {"type": "string"},
    "evidence_ids": {"type": "array", "items": {"type": "string"}},
    "invalidation": {"type": "array", "items": {"type": "string"}},
    "thesis_type": {"type": "string"},
    "evaluation_kind": {"type": "string", "enum": ["process", "timing_result", "thesis_result", "mixed"]}
  },
  "additionalProperties": true
}
